#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
            // ---- Left half ----
            // Row 0: 4 keys
                &kp N2      &kp N3      &kp N4      &kp N5
            // Row 1: 6 keys
                &kp ESC     &kp N1      &kp W       &kp E       &kp R       &kp T
            // Row 2: 6 keys
                &kp TAB     &kp Q       &kp S       &kp D       &kp F       &kp G
            // Row 3: 6 keys + encoder button
                &kp CAPS    &kp A       &kp X       &kp C       &kp V       &kp B       &kp C_MUTE
            // Row 4: 7 keys
                &kp LSHFT   &kp Z       &kp UP      &mo 1       &kp LALT    &kp SPACE   &kp BSPC
            // Row 5: 7 keys
                &kp LCTRL   &kp LEFT    &kp DOWN    &kp RIGHT   &kp LGUI    &kp PG_UP   &bt BT_CLR

            // ---- Right half ----
            // Row 0: 4 keys
                &kp N6      &kp N7      &kp N8      &kp N9
            // Row 1: 6 keys
                &kp Y       &kp U       &kp I       &kp O       &kp P       &kp BSPC
            // Row 2: 6 keys
                &kp H       &kp J       &kp K       &kp L       &kp SEMI    &kp SQT
            // Row 3: 6 keys + encoder button
                &kp N       &kp M       &kp COMMA   &kp DOT     &kp FSLH    &kp RET     &kp C_PP
            // Row 4: 7 keys
                &kp RSHFT   &kp N0      &kp MINUS   &kp EQUAL   &kp BSLH    &kp DEL     &kp RGUI
            // Row 5: 7 keys
                &kp RCTRL   &kp HOME    &kp END     &kp PG_UP   &kp PG_DN   &kp RALT    &trans
            >;

            // Left encoder: volume, Right encoder: track skip
            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN &inc_dec_kp C_NEXT C_PREV>;
        };

        fn_layer {
            bindings = <
            // ---- Left half ----
            // Row 0
                &trans  &trans  &trans  &trans
            // Row 1
                &trans  &trans  &trans  &trans  &trans  &trans
            // Row 2
                &trans  &trans  &trans  &trans  &trans  &trans
            // Row 3
                &trans  &trans  &trans  &trans  &trans  &trans  &trans
            // Row 4
                &trans  &trans  &trans  &trans  &trans  &trans  &trans
            // Row 5
                &trans  &trans  &trans  &trans  &trans  &trans  &trans

            // ---- Right half ----
            // Row 0
                &trans  &trans  &trans  &trans
            // Row 1
                &trans  &trans  &trans  &trans  &trans  &trans
            // Row 2
                &trans  &trans  &trans  &trans  &trans  &trans
            // Row 3
                &trans  &trans  &trans  &trans  &trans  &trans  &trans
            // Row 4
                &trans  &trans  &trans  &trans  &trans  &trans  &trans
            // Row 5
                &trans  &trans  &trans  &trans  &trans  &trans  &trans
            >;

            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN &inc_dec_kp C_NEXT C_PREV>;
        };
    };
};
