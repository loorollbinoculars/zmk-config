#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
            // Row 0: 4 keys
                &kp N6      &kp N7      &kp N8      &kp N9
            // Row 1: 6 keys
                &kp Y       &kp U       &kp I       &kp O       &kp P       &kp BSPC
            // Row 2: 6 keys
                &kp H       &kp J       &kp K       &kp L       &kp SEMI    &kp SQT
            // Row 3: 6 keys + encoder button
                &kp N       &kp M       &kp COMMA   &kp DOT     &kp FSLH    &kp RET     &kp C_PP
            // Row 4: 7 keys
                &kp RSHFT   &kp N0      &kp MINUS   &kp EQUAL   &kp BSLH    &kp DEL     &kp RGUI
            // Row 5: 7 keys
                &kp RCTRL   &kp HOME    &kp END     &kp PG_UP   &kp PG_DN   &kp RALT    &trans
            >;

            sensor-bindings = <&inc_dec_kp C_NEXT C_PREV>;
        };
    };
};
